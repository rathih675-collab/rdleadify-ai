DATABASE_URL="postgresql://user:password@localhost:5432/rdleadify_ai"
JWT_SECRET="replace-with-a-long-random-secret"

# Required for login security verification.
# Allow localhost and your Vercel production hostname in the Cloudflare widget settings.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional OpenAI integration.
# When set, /api/ai/chat uses OpenAI for replies.
# When missing, RDLeadify AI falls back to local deterministic lead qualification replies.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional Google integration.
# When any required Google value is missing, RDLeadify AI uses Demo Mode and stores sync logs locally.
# When all values are present, APIs return REAL_OAUTH_PENDING and are ready for the Google OAuth adapter.
APP_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/oauth/callback"
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_CALENDAR_ID=""
