generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_AGENT
  SUPPORT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum ContactType {
  LEAD
  CUSTOMER
  PARTNER
  VENDOR
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AgentType {
  SALES
  SUPPORT
  QUALIFICATION
  FOLLOW_UP
  CUSTOM
}

enum IntegrationStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AIConversationChannel {
  CHAT
  VOICE
}

enum InboxChannel {
  WHATSAPP
  WEBSITE_CHAT
  FACEBOOK_MESSENGER
  INSTAGRAM
  FACEBOOK_LEAD_ADS
  LINKEDIN
  EMAIL
  VOICE_AGENT
  API_WEBHOOK
  MANUAL
}

enum InboxMessageType {
  TEXT
  IMAGE
  PDF
  AUDIO
  VOICE
  VIDEO
  DOCUMENT
  LOCATION
  CONTACT
  TEMPLATE
}

enum InboxSender {
  CUSTOMER
  AGENT
  AI
  SYSTEM
  INTERNAL
}

enum InboxConversationStatus {
  OPEN
  PENDING
  RESOLVED
  LOST
  SPAM
}

enum InboxMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model Workspace {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  slug        String   @unique
  description String?
  website     String?
  timezone    String   @default("UTC")

  users            User[]
  roles            Role[]
  permissions      Permission[]
  leads            Lead[]
  inboxConversations InboxConversation[]
  googleSheetSyncLogs GoogleSheetSyncLog[]
  calendarBookingLogs CalendarBookingLog[]
  contacts         Contact[]
  companies        Company[]
  tags             Tag[]
  tasks            Task[]
  pipelines        Pipeline[]
  pipelineStages   PipelineStage[]
  campaigns        Campaign[]
  dripCampaigns    DripCampaign[]
  whatsAppAccounts WhatsAppAccount[]
  whatsAppMessages WhatsAppMessage[]
  aiAgents         AIAgent[]
  aiConversationLogs AIConversationLog[]
  automationWorkflows AutomationWorkflow[]
  automationExecutionLogs AutomationExecutionLog[]
  automationTemplates AutomationTemplate[]
  appointments     Appointment[]
  integrations     Integration[]
  apiKeys          ApiKey[]
  webhooks         Webhook[]
  activityLogs     ActivityLog[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  sessions AuthSession[]
  refreshTokens RefreshToken[]
  businessMemory BusinessMemory?
  knowledgeDocuments KnowledgeDocument[]
  visitorMemories VisitorMemory[]
  conversations Conversation[]
  conversationMemories ConversationMemory[]
  aiPrompts AiPrompt[]
  leadMemories LeadMemory[]
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  roleId      String?
  email       String
  passwordHash String
  name        String?
  avatarUrl   String?
  phone       String?
  userRole    UserRole @default(SALES_AGENT)
  isActive    Boolean  @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt DateTime?
  failedLoginAttempts Int @default(0)
  lockedUntil DateTime?
  lastLoginIp String?
  lastLoginUserAgent String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)

  assignedLeads Lead[]
  assignedInboxConversations InboxConversation[]
  inboxMessages InboxMessage[]
  assignedTasks Task[]
  appointments  Appointment[]
  apiKeys       ApiKey[]
  activityLogs  ActivityLog[]
  aiConversationLogs AIConversationLog[]
  automationWorkflows AutomationWorkflow[]
  automationExecutionLogs AutomationExecutionLog[]
  automationTemplates AutomationTemplate[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  sessions AuthSession[]
  refreshTokens RefreshToken[]

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([roleId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int      @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int      @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([expiresAt])
}

model AuthSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String
  workspaceId String
  refreshTokenHash String @unique
  ipAddress   String?
  userAgent   String?
  device      String?
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String
  workspaceId String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model Role {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  description String?
  isSystem    Boolean @default(false)

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users       User[]
  permissions Permission[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Permission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  key         String
  name        String
  description String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roles     Role[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId    String
  assignedUserId String?
  companyId      String?
  contactId      String?
  pipelineId     String?
  stageId        String?
  title          String
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  source         String?
  detectedLanguage String?
  preferredLanguage String?
  country       String?
  timezone      String?
  status         LeadStatus @default(NEW)
  score          Int        @default(0)
  value          Decimal?   @db.Decimal(12, 2)
  notes          String?

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedUser User?          @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  company      Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  pipeline     Pipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stage        PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  tags             Tag[]
  tasks            Task[]
  whatsAppMessages WhatsAppMessage[]
  appointments     Appointment[]
  activityLogs     ActivityLog[]
  inboxConversations InboxConversation[]
  googleSheetSyncLogs GoogleSheetSyncLog[]
  calendarBookingLogs CalendarBookingLog[]
  leadMemory LeadMemory?

  @@index([workspaceId])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([contactId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([status])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, source])
  @@index([workspaceId, score])
  @@index([workspaceId, email])
  @@index([workspaceId, phone])
}

model InboxConversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId      String
  leadId           String?
  assignedUserId   String?
  channel          InboxChannel
  conversationId   String
  customerName     String?
  customerPhone    String?
  customerEmail    String?
  lastMessage      String?
  lastMessageType  InboxMessageType?
  lastMessageTime  DateTime?
  unreadCount      Int      @default(0)
  status           InboxConversationStatus @default(OPEN)
  language         String?
  leadScore        Int      @default(0)
  aiSummary        String?
  buyingIntent     String?
  sentiment        String?
  recommendedNextAction String?
  tags             String[] @default([])
  metadata         Json?

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUser User?    @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages     InboxMessage[]

  @@unique([workspaceId, channel, conversationId])
  @@index([workspaceId])
  @@index([leadId])
  @@index([assignedUserId])
  @@index([channel])
  @@index([status])
  @@index([lastMessageTime])
  @@index([leadScore])
  @@index([workspaceId, status, lastMessageTime])
  @@index([workspaceId, channel, lastMessageTime])
  @@index([workspaceId, leadScore])
}

model InboxMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  conversationId String
  userId         String?
  sender         InboxSender
  messageType    InboxMessageType @default(TEXT)
  text           String?
  mediaUrl       String?
  aiGenerated    Boolean @default(false)
  timestamp      DateTime @default(now())
  status         InboxMessageStatus @default(SENT)
  metadata       Json?

  conversation InboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([userId])
  @@index([sender])
  @@index([messageType])
  @@index([timestamp])
  @@index([status])
}

model GoogleSheetSyncLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  workspaceId String
  leadId      String?
  status      String
  payload     Json
  response    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
}

model CalendarBookingLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  workspaceId String
  leadId      String?
  title       String
  startTime   DateTime
  endTime     DateTime
  attendeeEmail String?
  attendeePhone String?
  status      String
  response    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([status])
  @@index([startTime])
  @@index([createdAt])
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  companyId   String?
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  jobTitle    String?
  type        ContactType @default(LEAD)
  notes       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  leads            Lead[]
  tags             Tag[]
  tasks            Task[]
  whatsAppMessages WhatsAppMessage[]
  appointments     Appointment[]

  @@index([workspaceId])
  @@index([companyId])
  @@index([email])
}

model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  domain      String?
  industry    String?
  size        String?
  website     String?
  phone       String?
  address     String?
  notes       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contacts Contact[]
  leads    Lead[]
  tags     Tag[]
  tasks    Task[]

  @@index([workspaceId])
  @@index([domain])
}

model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  color       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  leads     Lead[]
  contacts  Contact[]
  companies Company[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Task {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId    String
  assignedUserId String?
  leadId         String?
  contactId      String?
  companyId      String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueAt          DateTime?
  completedAt    DateTime?

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedUser User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact      Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assignedUserId])
  @@index([leadId])
  @@index([contactId])
  @@index([companyId])
  @@index([status])
  @@index([dueAt])
}

model Pipeline {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  description String?
  isDefault   Boolean @default(false)

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages    PipelineStage[]
  leads     Lead[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model PipelineStage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  pipelineId  String
  name        String
  position    Int
  probability Int     @default(0)
  color       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline  Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@unique([pipelineId, position])
  @@unique([pipelineId, name])
  @@index([workspaceId])
  @@index([pipelineId])
}

model Campaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  channel     String?
  startsAt    DateTime?
  endsAt      DateTime?

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dripCampaigns DripCampaign[]
  messages      WhatsAppMessage[]

  @@index([workspaceId])
  @@index([status])
}

model DripCampaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  campaignId  String?
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  steps       Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([status])
}

model WhatsAppAccount {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId     String
  displayName     String
  phoneNumber     String
  provider        String?
  providerAccount String?
  isActive        Boolean @default(true)
  metadata        Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  WhatsAppMessage[]

  @@unique([workspaceId, phoneNumber])
  @@index([workspaceId])
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId       String
  whatsAppAccountId String?
  campaignId        String?
  leadId            String?
  contactId         String?
  direction         String
  fromNumber        String
  toNumber          String
  body              String
  status            String?
  providerMessageId String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount? @relation(fields: [whatsAppAccountId], references: [id], onDelete: SetNull)
  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead            Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact         Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([whatsAppAccountId])
  @@index([campaignId])
  @@index([leadId])
  @@index([contactId])
  @@index([providerMessageId])
}

model AIAgent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId   String
  name          String
  type          AgentType @default(CUSTOM)
  description   String?
  systemPrompt  String?
  model         String?
  configuration Json?
  isActive      Boolean   @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
}

model AIConversationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  workspaceId String
  userId      String?
  channel     AIConversationChannel
  messages    Json
  summary     String?
  leadScore   Int      @default(0)
  status      String   @default("CAPTURED")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@index([workspaceId, channel, createdAt])
  @@index([workspaceId, status, createdAt])
}

model BusinessMemory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String @unique
  businessName String?
  industry String?
  description String?
  products String?
  services String?
  pricing String?
  faqs String?
  workingHours String?
  address String?
  contactDetails String?
  website String?
  socialLinks Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model KnowledgeDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name String
  type String
  sourceUrl String?
  mimeType String?
  size Int?
  status String @default("PROCESSED")
  extractedText String
  summary String?
  metadata Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model VisitorMemory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  visitorKey String
  name String?
  phone String?
  email String?
  business String?
  preferredLanguage String?
  previousRequirements String[] @default([])
  previousSummaries String[] @default([])
  lastAiResponse String?
  previousConversations Int @default(0)
  previousAppointments Int @default(0)
  buyingIntent String?
  lastVisit DateTime @default(now())
  lastAiSummary String?
  lastConversationId String?
  leadId String?
  metadata Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, visitorKey])
  @@index([workspaceId])
  @@index([phone])
  @@index([email])
  @@index([leadId])
  @@index([business])
  @@index([preferredLanguage])
  @@index([lastVisit])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId String?
  leadId String?
  title String?
  channel String @default("CHAT")
  status String @default("OPEN")
  summary String?
  leadScore Int @default(0)
  metadata Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages Message[]
  memory ConversationMemory?

  @@index([workspaceId])
  @@index([userId])
  @@index([leadId])
  @@index([channel])
  @@index([status])
  @@index([updatedAt])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationId String
  role String
  content String
  metadata Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

model ConversationMemory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  conversationId String? @unique
  visitorKey String?
  name String?
  phone String?
  email String?
  business String?
  requirement String?
  budget String?
  timeline String?
  preferredLanguage String?
  summary String?
  lastAiResponse String?
  metadata Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([visitorKey])
  @@index([phone])
  @@index([email])
  @@index([business])
  @@index([preferredLanguage])
}

model AiPrompt {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name String
  purpose String @default("CHAT")
  systemPrompt String
  isActive Boolean @default(true)
  metadata Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([purpose])
  @@index([isActive])
}

model LeadMemory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  leadId String @unique
  summary String?
  requirement String?
  budget String?
  timeline String?
  buyingIntent String?
  preferredLanguage String?
  lastConversationId String?
  metadata Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([buyingIntent])
  @@index([preferredLanguage])
  @@index([lastConversationId])
}

model AutomationWorkflow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  createdById String?
  name        String
  description String?
  goal        String?
  aiAgent     String?
  pipeline    String?
  leadSource  String?
  triggerEvent String?
  workingHours String?
  timezone    String   @default("UTC")
  retryCount  Int      @default(0)
  retryDelay  String?
  status      CampaignStatus @default(DRAFT)
  nodes       Json
  edges       Json
  triggers    Json?
  conditions  Json?
  providerConfig Json?
  crmActions  Json?
  publishedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  executionLogs AutomationExecutionLog[]

  @@index([workspaceId])
  @@index([createdById])
  @@index([status])
  @@index([triggerEvent])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, triggerEvent, status])
}

model AutomationExecutionLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workflowId  String?
  userId      String?
  campaign    String
  lead        String
  currentStep String
  status      String
  executionTime Int?
  result      String?
  aiSummary   String?
  errors      Json?
  metadata    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow  AutomationWorkflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  user      User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workflowId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, workflowId, createdAt])
}

model AutomationTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  createdById String?
  name        String
  category    String
  description String?
  nodes       Json
  edges       Json
  triggers    Json?
  conditions  Json?
  crmActions  Json?
  providerConfig Json?
  isSystem    Boolean @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([createdById])
  @@index([category])
}

model Appointment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String?
  leadId      String?
  contactId   String?
  title       String
  description String?
  location    String?
  status      AppointmentStatus @default(SCHEDULED)
  startsAt    DateTime
  endsAt      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([leadId])
  @@index([contactId])
  @@index([startsAt])
  @@index([status])
  @@index([workspaceId, status, startsAt])
  @@index([workspaceId, leadId, startsAt])
}

model Integration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  provider    String
  name        String
  status      IntegrationStatus @default(PENDING)
  credentials Json?
  settings    Json?
  lastSyncedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhooks  Webhook[]

  @@unique([workspaceId, provider, name])
  @@index([workspaceId])
  @@index([status])
}

model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String?
  name        String
  keyHash     String   @unique
  prefix      String?
  scopes      String[]
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
}

model Webhook {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId   String
  integrationId String?
  name          String
  url           String
  events        String[]
  secretHash    String?
  isActive      Boolean @default(true)
  lastSentAt    DateTime?

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([integrationId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String?
  leadId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([leadId])
  @@index([entityType, entityId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, action, createdAt])
}
