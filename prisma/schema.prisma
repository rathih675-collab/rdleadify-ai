generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_AGENT
  SUPPORT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum ContactType {
  LEAD
  CUSTOMER
  PARTNER
  VENDOR
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AgentType {
  SALES
  SUPPORT
  QUALIFICATION
  FOLLOW_UP
  CUSTOM
}

enum IntegrationStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  ERROR
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Workspace {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  slug        String   @unique
  description String?
  website     String?
  timezone    String   @default("UTC")

  users            User[]
  roles            Role[]
  permissions      Permission[]
  leads            Lead[]
  contacts         Contact[]
  companies        Company[]
  tags             Tag[]
  tasks            Task[]
  pipelines        Pipeline[]
  pipelineStages   PipelineStage[]
  campaigns        Campaign[]
  dripCampaigns    DripCampaign[]
  whatsAppAccounts WhatsAppAccount[]
  whatsAppMessages WhatsAppMessage[]
  aiAgents         AIAgent[]
  appointments     Appointment[]
  integrations     Integration[]
  apiKeys          ApiKey[]
  webhooks         Webhook[]
  activityLogs     ActivityLog[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  sessions AuthSession[]
  refreshTokens RefreshToken[]
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  roleId      String?
  email       String
  passwordHash String
  name        String?
  avatarUrl   String?
  phone       String?
  userRole    UserRole @default(SALES_AGENT)
  isActive    Boolean  @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt DateTime?
  failedLoginAttempts Int @default(0)
  lockedUntil DateTime?
  lastLoginIp String?
  lastLoginUserAgent String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)

  assignedLeads Lead[]
  assignedTasks Task[]
  appointments  Appointment[]
  apiKeys       ApiKey[]
  activityLogs  ActivityLog[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  sessions AuthSession[]
  refreshTokens RefreshToken[]

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([roleId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int      @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int      @default(0)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([expiresAt])
}

model AuthSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String
  workspaceId String
  refreshTokenHash String @unique
  ipAddress   String?
  userAgent   String?
  device      String?
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String
  workspaceId String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model Role {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  description String?
  isSystem    Boolean @default(false)

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users       User[]
  permissions Permission[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Permission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  key         String
  name        String
  description String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roles     Role[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId    String
  assignedUserId String?
  companyId      String?
  contactId      String?
  pipelineId     String?
  stageId        String?
  title          String
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  source         String?
  status         LeadStatus @default(NEW)
  score          Int        @default(0)
  value          Decimal?   @db.Decimal(12, 2)
  notes          String?

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedUser User?          @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  company      Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  pipeline     Pipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stage        PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  tags             Tag[]
  tasks            Task[]
  whatsAppMessages WhatsAppMessage[]
  appointments     Appointment[]
  activityLogs     ActivityLog[]

  @@index([workspaceId])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([contactId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([status])
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  companyId   String?
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  jobTitle    String?
  type        ContactType @default(LEAD)
  notes       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  leads            Lead[]
  tags             Tag[]
  tasks            Task[]
  whatsAppMessages WhatsAppMessage[]
  appointments     Appointment[]

  @@index([workspaceId])
  @@index([companyId])
  @@index([email])
}

model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  domain      String?
  industry    String?
  size        String?
  website     String?
  phone       String?
  address     String?
  notes       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contacts Contact[]
  leads    Lead[]
  tags     Tag[]
  tasks    Task[]

  @@index([workspaceId])
  @@index([domain])
}

model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  color       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  leads     Lead[]
  contacts  Contact[]
  companies Company[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Task {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId    String
  assignedUserId String?
  leadId         String?
  contactId      String?
  companyId      String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueAt          DateTime?
  completedAt    DateTime?

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedUser User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact      Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assignedUserId])
  @@index([leadId])
  @@index([contactId])
  @@index([companyId])
  @@index([status])
  @@index([dueAt])
}

model Pipeline {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  description String?
  isDefault   Boolean @default(false)

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages    PipelineStage[]
  leads     Lead[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model PipelineStage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  pipelineId  String
  name        String
  position    Int
  probability Int     @default(0)
  color       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline  Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@unique([pipelineId, position])
  @@unique([pipelineId, name])
  @@index([workspaceId])
  @@index([pipelineId])
}

model Campaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  channel     String?
  startsAt    DateTime?
  endsAt      DateTime?

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dripCampaigns DripCampaign[]
  messages      WhatsAppMessage[]

  @@index([workspaceId])
  @@index([status])
}

model DripCampaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  campaignId  String?
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  steps       Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([status])
}

model WhatsAppAccount {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId     String
  displayName     String
  phoneNumber     String
  provider        String?
  providerAccount String?
  isActive        Boolean @default(true)
  metadata        Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  WhatsAppMessage[]

  @@unique([workspaceId, phoneNumber])
  @@index([workspaceId])
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId       String
  whatsAppAccountId String?
  campaignId        String?
  leadId            String?
  contactId         String?
  direction         String
  fromNumber        String
  toNumber          String
  body              String
  status            String?
  providerMessageId String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount? @relation(fields: [whatsAppAccountId], references: [id], onDelete: SetNull)
  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead            Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact         Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([whatsAppAccountId])
  @@index([campaignId])
  @@index([leadId])
  @@index([contactId])
  @@index([providerMessageId])
}

model AIAgent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId   String
  name          String
  type          AgentType @default(CUSTOM)
  description   String?
  systemPrompt  String?
  model         String?
  configuration Json?
  isActive      Boolean   @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
}

model Appointment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String?
  leadId      String?
  contactId   String?
  title       String
  description String?
  location    String?
  status      AppointmentStatus @default(SCHEDULED)
  startsAt    DateTime
  endsAt      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([leadId])
  @@index([contactId])
  @@index([startsAt])
  @@index([status])
}

model Integration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  provider    String
  name        String
  status      IntegrationStatus @default(PENDING)
  credentials Json?
  settings    Json?
  lastSyncedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhooks  Webhook[]

  @@unique([workspaceId, provider, name])
  @@index([workspaceId])
  @@index([status])
}

model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String?
  name        String
  keyHash     String   @unique
  prefix      String?
  scopes      String[]
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
}

model Webhook {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId   String
  integrationId String?
  name          String
  url           String
  events        String[]
  secretHash    String?
  isActive      Boolean @default(true)
  lastSentAt    DateTime?

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([integrationId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  userId      String?
  leadId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([leadId])
  @@index([entityType, entityId])
}
